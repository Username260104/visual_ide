generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  thumbnailUrl String? @map("thumbnail_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  nodes      Node[]
  directions Direction[]

  @@map("projects")
}

model Direction {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  color     String
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes   Node[]

  @@index([projectId])
  @@map("directions")
}

model Node {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  // Lineage
  parentNodeId String? @map("parent_node_id")
  directionId  String? @map("direction_id")

  // Source
  source      String  @default("imported") // 'ai-generated' | 'imported'
  prompt      String?
  seed        Int?
  modelUsed   String? @map("model_used")

  // Image dimensions
  width       Int?
  height      Int?
  aspectRatio String? @map("aspect_ratio")

  // Intent (JSON arrays stored as text)
  intentTags String[] @default([]) @map("intent_tags")
  changeTags String[] @default([]) @map("change_tags")
  note       String   @default("")

  // Status
  status       String  @default("unclassified")
  statusReason String? @map("status_reason")

  // Auto
  versionNumber Int @default(1) @map("version_number")

  // Canvas position
  positionX Float @default(0) @map("position_x")
  positionY Float @default(0) @map("position_y")

  // Relations
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  direction  Direction? @relation(fields: [directionId], references: [id], onDelete: SetNull)
  parentNode Node?      @relation("NodeTree", fields: [parentNodeId], references: [id], onDelete: SetNull)
  children   Node[]     @relation("NodeTree")

  @@index([projectId])
  @@index([directionId])
  @@index([parentNodeId])
  @@map("nodes")
}

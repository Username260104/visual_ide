# === Supabase ===
# Server-only. Never expose these through NEXT_PUBLIC_*.
# Supabase 프로젝트 Settings > Database > Connection string (Transaction mode)
DATABASE_URL="your-postgres-transaction-url"
# Supabase 프로젝트 Settings > Database > Connection string (Session mode)
DIRECT_URL="your-postgres-direct-url"

# Supabase 프로젝트 Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# === AI APIs ===
# Server-only. Keep secret keys in `.env` or your deployment provider's secret store.
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-3.1-flash-lite-preview"
# Optional. Leave empty to use the SDK default (`v1beta`).
GEMINI_API_VERSION="v1beta"
ANTHROPIC_API_KEY="your-anthropic-api-key"
REPLICATE_API_TOKEN="your-replicate-api-token"
